{
  "name": "@commerce-shipmondo/service-point-selector",
  "version": "1.0.0",
  "description": "Shipmondo service point selector for Drupal Commerce checkout and React shops",
  "type": "module",
  "main": "dist/service-point-selector.umd.js",
  "module": "dist/service-point-selector.esm.js",
  "exports": {
    ".": {
      "import": "./dist/service-point-selector.esm.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --mode umd && cp dist/service-point-selector.umd.js ../js/service-point-selector.umd.js",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.3",
    "vite-plugin-css-injected-by-js": "^3.5.2"
  }
}
